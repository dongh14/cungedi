# Browser-visible Supabase configuration. The publishable/anon key is public;
# database access is still enforced by authenticated sessions and RLS.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Local-only same-origin basemap path. Used when NEXT_PUBLIC_PMTILES_URL is empty.
NEXT_PUBLIC_PM_TILES_BASEMAP_PATH=/maps/base.pmtiles

# Public URL of the production PMTiles archive hosted in Vercel Blob or another
# Range-capable object store. Leave empty in local development.
NEXT_PUBLIC_PMTILES_URL=

# Optional deployment origin for integrations that need an explicit public URL.
# The current email/password redirects use app routes and do not require this.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-only DeepSeek configuration. Never prefix secrets with NEXT_PUBLIC_.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# Keep optional diagnostics quiet by default in copied local configuration.
# Safe development diagnostics can be enabled explicitly when debugging.
DEEPSEEK_DEBUG_LOGS=false
DEEPSEEK_DEBUG_RAW_RESPONSE=false
WORKFLOW_DEBUG_LOGS=false
